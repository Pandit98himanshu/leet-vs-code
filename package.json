{
  "name": "leetvscode",
  "displayName": "Leet-VS-Code",
  "version": "1.6.0",
  "main": "./dist/extension.js",
  "keywords": [
    "leetcode",
    "vscode"
  ],
  "author": "pandithimanshu",
  "publisher": "pandithimanshu",
  "license": "ISC",
  "engines": {
    "vscode": "^1.107.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:leetvscodeProblems",
    "onView:leetvscodeSubmissions",
    "onCommand:leetvscode.showDailyChallenge",
    "onCommand:leetvscode.searchProblem",
    "onCommand:leetvscode.viewAllProblems",
    "onCommand:leetvscode.showUserProfile",
    "onCommand:leetvscode.openSolution",
    "onCommand:leetvscode.submitSolution",
    "onCommand:leetvscode.setSession",
    "onCommand:leetvscode.clearSession",
    "onCommand:leetvscode.showMySubmissions"
  ],
  "description": "Browse LeetCode problems, view daily challenges, and look up user profiles directly in VS Code.",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "leetvscode",
          "title": "LeetCode",
          "icon": "media/leetcode.svg"
        }
      ],
      "panel": [
        {
          "id": "leetvscodePanel",
          "title": "LeetCode Test Results",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "leetvscode": [
        {
          "id": "leetvscodeProblems",
          "name": "All Problems",
          "icon": "$(list-unordered)"
        },
        {
          "id": "leetvscodeDailyQuestions",
          "name": "Daily Questions",
          "icon": "$(calendar)"
        },
        {
          "id": "leetvscodeSubmissions",
          "name": "My Submissions",
          "icon": "$(history)",
          "visibility": "collapsed"
        }
      ],
      "leetvscodePanel": [
        {
          "id": "leetvscodeTestResultsView",
          "name": "Test Results",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "leetvscode.showDailyChallenge",
        "title": "Show Daily Challenge",
        "icon": "$(flame)"
      },
      {
        "command": "leetvscode.searchProblem",
        "title": "Search Problem",
        "icon": "$(search)"
      },
      {
        "command": "leetvscode.viewAllProblems",
        "title": "View All Problems"
      },
      {
        "command": "leetvscode.showUserProfile",
        "title": "Show User Profile",
        "icon": "$(account)"
      },
      {
        "command": "leetvscode.openSolution",
        "title": "Open Solution File",
        "icon": "$(file-code)"
      },
      {
        "command": "leetvscode.submitSolution",
        "title": "Submit Solution",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "leetvscode.testSolution",
        "title": "Test Solution",
        "icon": "$(play)"
      },
      {
        "command": "leetvscode.setSession",
        "title": "Set Session Cookie",
        "icon": "$(key)"
      },
      {
        "command": "leetvscode.clearSession",
        "title": "Clear Session Cookie",
        "icon": "$(sign-out)"
      },
      {
        "command": "leetvscode.showMySubmissions",
        "title": "Show my recent Submissions",
        "icon": "$(history)"
      },
      {
        "command": "leetvscode.clearTestResults",
        "title": "Clear Test Results",
        "icon": "$(clear-all)"
      },
      {
        "command": "leetvscode.prevMonthDaily",
        "title": "Previous Month",
        "icon": "$(arrow-left)",
        "enablement": "leetvscode:hasPrevMonth"
      },
      {
        "command": "leetvscode.nextMonthDaily",
        "title": "Next Month",
        "icon": "$(arrow-right)",
        "enablement": "leetvscode:hasNextMonth"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "leetvscode.searchProblem",
          "when": "view == leetvscodeProblems",
          "group": "navigation@2"
        },
        {
          "command": "leetvscode.showUserProfile",
          "when": "view == leetvscodeProblems",
          "group": "navigation@3"
        },
        {
          "command": "leetvscode.setSession",
          "when": "view == leetvscodeProblems && !leetvscode:hasSession",
          "group": "navigation@4"
        },
        {
          "command": "leetvscode.clearSession",
          "when": "view == leetvscodeProblems && leetvscode:hasSession",
          "group": "navigation@4"
        },
        {
          "command": "leetvscode.prevMonthDaily",
          "when": "view == leetvscodeDailyQuestions",
          "group": "navigation@1"
        },
        {
          "command": "leetvscode.nextMonthDaily",
          "when": "view == leetvscodeDailyQuestions",
          "group": "navigation@2"
        },
        {
          "command": "leetvscode.showDailyChallenge",
          "when": "view == leetvscodeDailyQuestions",
          "group": "navigation@3"
        },
        {
          "command": "leetvscode.showMySubmissions",
          "when": "view == leetvscodeSubmissions && leetvscode:hasSession",
          "group": "navigation@0"
        },
        {
          "command": "leetvscode.clearTestResults",
          "when": "view == leetvscodeTestResultsView",
          "group": "navigation@0"
        }
      ]
    },
    "configuration": {
      "title": "Leet-VS-Code",
      "properties": {
        "leetvscode.defaultDifficulty": {
          "type": "string",
          "default": "All",
          "enum": [
            "All",
            "Easy",
            "Medium",
            "Hard"
          ],
          "description": "Default difficulty filter for prolem browsing"
        },
        "leetvscode.rootDir": {
          "type": "string",
          "default": "",
          "description": "Root directory for all LeetVSCode storage (solutions, cache, etc.). Leave empty to use the default (~/.leetvscode)."
        },
        "leetvscode.defaultLanguage": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "cpp",
            "java",
            "python3",
            "python",
            "c",
            "csharp",
            "javascript",
            "typescript",
            "php",
            "swift",
            "kotlin",
            "dart",
            "golang",
            "ruby",
            "scala",
            "rust",
            "racket",
            "erlang",
            "elixir"
          ],
          "enumDescriptions": [
            "No default",
            "C++",
            "Java",
            "Python 3",
            "Python",
            "C",
            "C#",
            "JavaScript",
            "TypeScript",
            "PHP",
            "Swift",
            "Kotlin",
            "Dart",
            "Go",
            "Ruby",
            "Scala",
            "Rust",
            "Racket",
            "Erlang",
            "Elixir"
          ],
          "description": "Default language for code snippets. The snippet panel will open in this language if available."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --watch",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "dependencies": {
    "leetcode-query": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.107.0",
    "@vscode/vsce": "^3.9.2",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}